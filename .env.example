# Copy this file to `.env` and fill in your key(s).
# `.env` is gitignored.

# ---------------------------------------------------------------------------
# Rendering backend for JS-rendered / anti-bot pages.
#   playwright = local Chromium (free, recommended)
#   jina       = Jina Reader API (paid, no local install)
#   disabled   = httpx only, skips rendering entirely
# ---------------------------------------------------------------------------
EUPRICE_RENDER=playwright

# ---------------------------------------------------------------------------
# Jina Reader API key — only needed if EUPRICE_RENDER=jina.
# Get one at https://jina.ai/?sui=apikey  (free tier covers small experiments).
# ---------------------------------------------------------------------------
JINA_API_KEY=

# ---------------------------------------------------------------------------
# Archive every fetched HTML page to data/snapshots/<date>/<sha256>.html.
# Useful for reproducibility (the case study can cite exact snapshots).
# Set to 0 to disable.
# ---------------------------------------------------------------------------
EUPRICE_ARCHIVE_HTML=1
